{
  "name": "@citadel-app/excalidraw",
  "version": "1.2.3",
  "description": "Whiteboard and diagramming with Excalidraw for Citadel.",
  "author": "Citadel Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/citadel-app/citadel-plugin-excalidraw.git"
  },
  "engines": {
    "citadel": ">=1.2.3"
  },
  "citadel": {
    "title": "Whiteboard",
    "icon": "assets/icon.svg",
    "renderer": "dist/renderer.js",
    "authorUrl": "https://github.com/citadel-app",
    "verified": true,
    "providesIpcs": [],
    "sidecars": [],
    "permissions": [
      "@citadel-app/base:plugins.getPluginPath",
      "@citadel-app/base:fs.readFile",
      "@citadel-app/base:fs.exists",
      "@citadel-app/base:fs.writeFile"
    ]
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "npm run build:renderer",
    "generate:marketplace": "node scripts/generate-marketplace-manifest.js",
    "build:renderer": "vite build --mode renderer"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "*",
    "lodash": "^4.17.21"
  },
  "peerDependencies": {
    "@citadel-app/core": "*",
    "@citadel-app/sdk": "*",
    "@citadel-app/ui": "*",
    "lucide-react": "*",
    "react": "*",
    "react-dom": "*",
    "react-router-dom": "*"
  },
  "devDependencies": {
    "@citadel-app/core": "^1.2.3",
    "@citadel-app/sdk": "^1.2.3",
    "@citadel-app/ui": "^1.2.3",
    "@types/lodash": "^4.17.0",
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.2.1",
    "lucide-react": "^0.453.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "typescript": "^5.6.3",
    "vite": "^5.0.0"
  }
}